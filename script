local activeTargetPos = nil 

RunService.RenderStepped:Connect(function()
    local rgb = Color3.fromHSV((tick() % 5) / 5, 1, 1)
    local screenCenter = Camera.ViewportSize / 2
    
    fovCircle.Visible = fovEnabled
    if fovEnabled then
        fovCircle.Size = UDim2.new(0, calculatedRadius * 2, 0, calculatedRadius * 2)
        stroke.Color = rgb
    end

    local bestTarget = nil
    local shortestDist = 9e9
    local triggerTarget = nil

    for _, plr in pairs(Players:GetPlayers()) do
        local tracer = tracers[plr]
        local char = plr.Character
        if char and isEnemy(plr) then
            local head = char:FindFirstChild("Head")
            local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso") or char:FindFirstChild("HumanoidRootPart")
            local highlight = char:FindFirstChild("Highlight") or Instance.new("Highlight", char)
            
            if head and torso then
                local distFromMe = (head.Position - Camera.CFrame.Position).Magnitude
                local headPos, headOnScreen = Camera:WorldToViewportPoint(head.Position)
                local torsoPos, torsoOnScreen = Camera:WorldToViewportPoint(torso.Position)
                local fovDist = (Vector2.new(headPos.X, headPos.Y) - screenCenter).Magnitude

                if tracer then
                    tracer.Visible = (tracersEnabled and torsoOnScreen and distFromMe <= maxDistance)
                    if tracer.Visible then
                        tracer.From = screenCenter 
                        tracer.To = Vector2.new(torsoPos.X, torsoPos.Y)
                        tracer.Color = rgb
                    end
                end

                highlight.Enabled = chamsEnabled; highlight.FillColor = rgb

                if distFromMe <= maxDistance then
                    local targetPart = nil
                    local targetPos = nil
                    local targetOnScreen = false
                    local targetFovDist = 9e9

                    if aimTarget == "Head" then
                        targetPart = getValidHead(char)
                        if targetPart then
                            targetPos, targetOnScreen = Camera:WorldToViewportPoint(targetPart.Position)
                            targetFovDist = targetOnScreen and (Vector2.new(targetPos.X, targetPos.Y) - screenCenter).Magnitude or 9e9
                        end
                    elseif aimTarget == "Torso" then
                        targetPart = getValidPart(char, torso.Name)
                        if targetPart then
                            targetPos, targetOnScreen = Camera:WorldToViewportPoint(targetPart.Position)
                            targetFovDist = targetOnScreen and (Vector2.new(targetPos.X, targetPos.Y) - screenCenter).Magnitude or 9e9
                        end
                    elseif aimTarget == "Random" then
                        local validHead = getValidHead(char)
                        local validTorso = getValidPart(char, torso.Name)
                        local parts = {}
                        if validHead then table.insert(parts, validHead) end
                        if validTorso then table.insert(parts, validTorso) end
                        if #parts > 0 then
                            targetPart = parts[math.random(1, #parts)]
                            targetPos, targetOnScreen = Camera:WorldToViewportPoint(targetPart.Position)
                            targetFovDist = targetOnScreen and (Vector2.new(targetPos.X, targetPos.Y) - screenCenter).Magnitude or 9e9
                        end
                    elseif aimTarget == "Closest to Crosshair" then
                        local candidates = {}
                        local validHead = getValidHead(char)
                        if validHead then
                            local pos, on = Camera:WorldToViewportPoint(validHead.Position)
                            if on then
                                table.insert(candidates, {part = validHead, dist = (Vector2.new(pos.X, pos.Y) - screenCenter).Magnitude})
                            end
                        end
                        local validTorso = getValidPart(char, torso.Name)
                        if validTorso then
                            local pos, on = Camera:WorldToViewportPoint(validTorso.Position)
                            if on then
                                table.insert(candidates, {part = validTorso, dist = (Vector2.new(pos.X, pos.Y) - screenCenter).Magnitude})
                            end
                        end
                        if #candidates > 0 then
                            table.sort(candidates, function(a, b) return a.dist < b.dist end)
                            targetPart = candidates[1].part
                            targetPos, targetOnScreen = Camera:WorldToViewportPoint(targetPart.Position)
                            targetFovDist = candidates[1].dist
                        end
                    end

                    if targetPart and targetOnScreen then
                        if triggerBotEnabled and targetFovDist <= triggerBotRadius then
                            triggerTarget = targetPart
                        end
                        if getgenv().SoftLockEnabled then
                            if targetFovDist <= calculatedRadius and targetFovDist < shortestDist then
                                shortestDist = targetFovDist; bestTarget = targetPart
                            end
                        elseif getgenv().SilentAimEnabled then
                            if targetFovDist < shortestDist then
                                shortestDist = targetFovDist; bestTarget = targetPart
                            end
                        end
                    end
                end
            end
        elseif tracer then tracer.Visible = false end
    end
    activeTargetPos = bestTarget and bestTarget.Position or nil

    if triggerBotEnabled and triggerTarget and tick() - lastTriggerTime >= triggerBotDelay then
        lastTriggerTime = tick()
        -- Fire using the weapon's remote or direct call (avoids mouse visibility)
        pcall(function()
            local weapon = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
            if weapon then
                local fire = weapon:FindFirstChild("Fire") or weapon:FindFirstChild("Shoot")
                if fire and fire:IsA("RemoteEvent") then
                    fire:FireServer()
                elseif fire and fire:IsA("RemoteFunction") then
                    fire:InvokeServer()
                end
            end
        end)
    end
end)

RunService.Heartbeat:Connect(function()
    if not rageModeEnabled then
        rageTargetPos = nil
        if rageLabel then
            rageLabel.Text = "RAGE OFF"
            rageLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        end
        return
    end

    Camera = workspace.CurrentCamera
    local camPos = Camera.CFrame.Position
    local best, bestDist = nil, math.huge
    local center = Camera.ViewportSize / 2

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and rageValid(plr, camPos) then
            local pos, on = Camera:WorldToViewportPoint(plr.Character.Head.Position)
            if on then
                local d = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                if d < bestDist then
                    bestDist = d
                    best = plr
                end
            end
        end
    end

    rageTargetPos = best and best.Character.Head.Position or nil
    if rageLabel then
        if best then
            rageLabel.Text = "RAGE LOCK: " .. best.Name:upper()
            rageLabel.TextColor3 = Color3.fromRGB(0, 255, 150)
        else
            rageLabel.Text = "RAGE SCANNING..."
            rageLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        end
    end
end)

local old; old = hookmetamethod(game, "__index", newcclosure(function(self, idx)
    local currentTarget = rageModeEnabled and rageTargetPos or activeTargetPos
    if (rageModeEnabled or getgenv().SilentAimEnabled or getgenv().SoftLockEnabled) and currentTarget and not checkcaller() and idx == "ViewportSize" and self == Camera then
        local pos, on = Camera:WorldToViewportPoint(currentTarget)
        if on then return Vector2.new(pos.X * 2, pos.Y * 2) end
    end
    return old(self, idx)
end))

